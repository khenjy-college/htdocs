<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BookmasterDetailActivity">

    <TextView
        android:id="@+id/judulISBN"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ISBN"
        android:textSize="24dp"/>

    <TextView
        android:id="@+id/judulNama"
        android:layout_marginTop="16dp"
        android:layout_below="@id/judulISBN"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nama"
        android:textSize="24dp"/>

    <TextView
        android:id="@+id/judulTglTambah"
        android:layout_marginTop="16dp"
        android:layout_below="@id/judulNama"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tanggal Tambah"
        android:textSize="24dp"/>


</RelativeLayout>