<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PhonebookDetailActivity">

    <TextView
        android:id="@+id/judulId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Id"
        android:textSize="24dp"/>

    <TextView
        android:id="@+id/judulNama"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/judulId"
        android:text="Nama"
        android:textSize="24dp"/>

    <TextView
        android:id="@+id/judulNoHp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/judulNama"
        android:text="Nomor Hp"
        android:textSize="24dp"/>

    <TextView
        android:id="@+id/judulTglLahir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/judulNoHp"
        android:text="Tanggal Lahir"
        android:textSize="24dp"/>


</RelativeLayout>