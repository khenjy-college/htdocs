<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplikasi"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel1"
                app:layout_constraintEnd_toEndOf="@+id/buttonTabel1"
                app:layout_constraintStart_toStartOf="@+id/buttonTabel1"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/buttonTabel1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel1_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text" />

            <Button
                android:id="@+id/buttonTabel2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel2_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel1" />

            <Button
                android:id="@+id/buttonTabel3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel3_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel2" />

            <Button
                android:id="@+id/buttonTabel4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel4_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel5"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel3" />

            <Button
                android:id="@+id/buttonTabel5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel5_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel6"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel4" />

            <Button
                android:id="@+id/buttonTabel6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel6_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel7"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel5" />

            <Button
                android:id="@+id/buttonTabel7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel7_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel6" />

            <Button
                android:id="@+id/buttonTabel8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel8_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel9"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel7" />

            <Button
                android:id="@+id/buttonTabel9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel9_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel10"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel8" />

            <Button
                android:id="@+id/buttonTabel10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel10_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@+id/buttonTabel11"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttonTabel9" />

            <Button
                android:id="@+id/buttonTabel11"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tabel11_alias"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

