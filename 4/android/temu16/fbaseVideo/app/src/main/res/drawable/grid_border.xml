<!-- res/drawable/grid_border.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@color/teal_200" />
    <stroke
        android:width="2dp"
        android:color="@color/black" />
    <corners android:radius="8dp" />

    <!-- Padding to make the stroke appear outside -->
    <padding
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp" />
</shape>
