<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ubah Data Laundry"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:layout_alignParentTop="true"/>

    <TextView
        android:id="@+id/tv_nama"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama:"
        android:textSize="16sp"
        android:layout_below="@id/tv_title"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/et_nama"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan nama"
        android:layout_below="@id/tv_nama"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_alamat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alamat:"
        android:textSize="16sp"
        android:layout_below="@id/et_nama"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/et_alamat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan alamat"
        android:layout_below="@id/tv_alamat"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_telepon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Telepon:"
        android:textSize="16sp"
        android:layout_below="@id/et_alamat"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/et_telepon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan nomor telepon"
        android:layout_below="@id/tv_telepon"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btn_ubah"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ubah"
        android:layout_below="@id/et_telepon"
        android:layout_marginTop="24dp"
        android:layout_centerHorizontal="true"/>

</RelativeLayout>
